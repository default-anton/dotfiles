#!/usr/bin/env bash

set -e

tool="$1"
version="${2:-latest}"

case "$tool" in
  mlx-audio)
    # Source: https://github.com/Blaizzy/mlx-audio
    package_spec="mlx-audio[all]"

    if [[ "$version" != "latest" ]]; then
      package_spec="${package_spec}==${version}"
    fi

    uv tool install "$package_spec" --force --prerelease=allow --python 3.11 --with "numpy<2.0.0" --with "spacy<4.0.0" --with "typer>=0.9.0" --with "pip" --with "python-multipart"
    ;;
  claude)
    brew upgrade --cask claude-code@latest
    ;;
  pi)
    # Source: https://github.com/badlogic/pi-mono/tree/main/packages/coding-agent
    mise use --global "npm:@mariozechner/pi-coding-agent@${version}"
    ;;
  codex)
    mise use --global "npm:@openai/codex@${version}"
    ;;
  jagc)
    mise use --global "npm:jagc@${version}"
    ;;
  gemini)
    mise use --global "npm:@google/gemini-cli@${version}"
    ;;
  *)
    echo "Usage: update {mlx-audio|claude|pi|codex|jagc|gemini} [version]"
    exit 1
    ;;
esac
